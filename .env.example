# =============================================================================
# Appliance Support — copy to .env and adjust.
#   cp .env.example .env
# Used by local uvicorn and docker compose (variable substitution).
# =============================================================================

# --- Core service ------------------------------------------------------------
SUPPORT_PORT=8090
# Local default; Docker compose uses /data/support.db
SUPPORT_DB_PATH=./data/support.db
SUPPORT_RATE_LIMIT_PER_HOUR=10
SUPPORT_TICKET_RETENTION_DAYS=30
SUPPORT_TICKET_LIST_LIMIT=20
# Keep per-ticket worktrees + _ai/ after diagnosis (human investigation)
SUPPORT_KEEP_TICKET_WORKTREES=false

# --- Entitlement / billing ---------------------------------------------------
# stub | postgres
BILLING_ADAPTER=stub
# stub mode:
SUPPORT_FREE_FOR_ALL=true
# SUPPORT_DENIED_APPLIANCE_IDS=
# SUPPORT_ENTITLED_APPLIANCE_IDS=
# postgres mode (nocloud DB):
# DATABASE_URL=postgresql://user:pass@localhost:5432/nocloud

# --- Code context (required for real diagnosis) ------------------------------
# Source clones must be git repos (writable .git for worktree registration).
# Console: usually the appliance-console checkout/submodule.
CODE_ROOT_APPLIANCE_CONSOLE=/home/devel/ownedge/appliance-console
# Backend: git root that contains controller code. If inferedge-phase1 is not its
# own repo, point at the monorepo root (e.g. /home/devel/ownedge), not the subdir.
CODE_ROOT_APPLIANCE_BACKEND=/home/devel/ownedge
# Prefer a path outside the app tree so `uvicorn --reload` does not restart mid-job.
CODE_WORKTREE_ROOT=/tmp/appliance-support-worktrees

# --- AI CLI ------------------------------------------------------------------
# stub = rule-based (no external tool); cli = subprocess (Grok or other)
AI_CLI_ADAPTER=stub
# Production Grok (host: grok login; PATH must include ~/.grok/bin):
# AI_CLI_ADAPTER=cli
# AI_CLI_COMMAND=./scripts/ai_diagnose_grok.sh
# Dev stub CLI:
# AI_CLI_COMMAND=python3 scripts/ai_diagnose_stub.py
# Placeholders: {prompt_file} {bundle_file} {code_root} {code_roots} {ticket_id}
AI_CLI_COMMAND=
AI_CLI_USE_PROMPT_FILE=true
AI_CLI_TIMEOUT_SEC=300
# code_root | none
AI_CLI_CWD=code_root
# backend | console | first  (primary worktree = AI_CODE_ROOT / cwd)
AI_CLI_PRIMARY_ROOT=backend
AI_PROMPT_TEMPLATE_PATH=prompts/diagnose.txt
# Grok wrapper only:
GROK_BIN=grok
AI_GROK_MAX_TURNS=40
# AI_DIAGNOSIS_SCHEMA=schemas/diagnosis-result.v1.json
# Docker: host path mounted at /root/.grok
GROK_HOME=

# Job-level diagnosis budget (includes CLI retries)
DIAGNOSIS_TIMEOUT_SEC=360
DIAGNOSIS_MAX_RETRIES=2
DIAGNOSIS_RETRY_BACKOFF_SEC=2

# --- Ops alerts (invalid version / code-context failures) --------------------
SUPPORT_ALERT_EMAIL=support@ownedge.ai
# If SMTP_HOST is unset, alerts are logged only
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@ownedge.ai
SMTP_USE_TLS=true

# --- Optional vendor workflow ------------------------------------------------
GITHUB_ISSUE_ENABLED=false
GITHUB_TOKEN=
# owner/repo
GITHUB_REPO=
GITHUB_ISSUE_LABELS=support,appliance
# low | medium | high
GITHUB_ISSUE_MIN_CONFIDENCE=high
SUPPORT_WEBHOOK_URL=
SUPPORT_WEBHOOK_SECRET=
